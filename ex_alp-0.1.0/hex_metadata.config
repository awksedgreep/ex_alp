 [<<"lib">>,<<"lib/ex_alp.ex">>,<<"lib/ex_alp">>,<<"lib/ex_alp/native.ex">>,
  <<"c_src">>,<<"c_src/alp">>,<<"c_src/alp/encoder.hpp">>,
  <<"c_src/alp/storer.hpp">>,<<"c_src/alp/rd.hpp">>,
  <<"c_src/alp/config.hpp">>,<<"c_src/alp/decoder.hpp">>,
  <<"c_src/alp/falp.hpp">>,<<"c_src/alp/constants.hpp">>,
  <<"c_src/alp/sampler.hpp">>,<<"c_src/alp/common.hpp">>,
  <<"c_src/alp_nif.cpp">>,<<"Makefile">>,<<"mix.exs">>,<<"README.md">>,
  <<"LICENSE">>]}.
