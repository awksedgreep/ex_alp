{<<"name">>,<<"ex_alp">>}.
{<<"version">>,<<"0.1.0">>}.
{<<"description">>,
 <<"ALP (Adaptive Lossless floating-Point) compression for Elixir. 2.5x better compression and 2x faster than Gorilla encoding for time series data. NIF wrapper around the SIGMOD 2024 reference implementation.">>}.
{<<"elixir">>,<<"~> 1.18">>}.
{<<"app">>,<<"ex_alp">>}.
{<<"licenses">>,[<<"MIT">>]}.
